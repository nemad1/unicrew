rating\n    }\n\n    contact_signals {\n        string id PK\n        string contact_id FK\n        string source_message_id FK\n        string signal_type\n        string label\n    }\n\n    routing_rules {\n        string id PK\n        string keyword\n        string intent\n        string handler\n    }\n\n    policy_suggestions {\n        string id PK\n        string submitted_by FK\n        string reviewed_by FK\n        string rule\n        string status\n    }\n\n    %% Relationships\n    teams ||--o{ internal_users : \&quot;has_members\&quot;\n    internal_users ||--o| teams : \&quot;leads (lead_id)\&quot;\n    \n    internal_users ||--o{ contacts : \&quot;assigned_to\&quot;\n    teams ||--o{ contacts : \&quot;handles\&quot;\n    internal_users ||--o{ contacts : \&quot;pending_feedback_for\&quot;\n    \n    contacts ||--o{ interaction_logs : \&quot;has_logs\&quot;\n    interaction_logs ||--o| interaction_logs : \&quot;replies_to\&quot;\n    interaction_logs ||--o| contacts : \&quot;last_analyzed\&quot;\n    \n    teams ||--o{ kanban_boards : \&quot;owns\&quot;\n    kanban_boards ||--o{ kanban_stages : \&quot;contains\&quot;\n    kanban_stages ||--o{ kanban_cards : \&quot;holds\&quot;\n    contacts ||--o| kanban_cards : \&quot;represented_by\&quot;\n    internal_users ||--o{ kanban_cards : \&quot;assigned_to\&quot;\n    \n    contacts ||--o{ contact_notes : \&quot;has_notes\&quot;\n    internal_users ||--o{ contact_notes : \&quot;authors\&quot;\n    \n    contacts ||--o{ audit_logs : \&quot;generates\&quot;\n    internal_users ||--o{ audit_logs : \&quot;performs_action\&quot;\n    \n    internal_users ||--|| ambassador_profiles : \&quot;has_profile\&quot;\n    internal_users ||--o{ ambassador_shifts : \&quot;works\&quot;\n    \n    contacts ||--o{ ambassador_feedback : \&quot;receives\&quot;\n    internal_users ||--o{ ambassador_feedback : \&quot;reviewed_by\&quot;\n    \n    contacts ||--o{ contact_signals : \&quot;emits\&quot;\n    interaction_logs ||--o{ contact_signals : \&quot;source_of\&quot;\n    \n    internal_users ||--o{ policy_suggestions : \&quot;submits\&quot;\n    internal_users ||--o{ policy_suggestions : \&quot;reviews\&quot;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="Bp3ZovvAPo1KQedRjp4e-331">
